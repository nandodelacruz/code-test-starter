# PostgreSQL connection string used by Prisma (see prisma/schema.prisma).
# Copy this file to `.env` and adjust credentials, host, port, and database name.
#
# Local example (create the database first, e.g. `createdb bookhaven`):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bookhaven?schema=public"

# DIRECT_URL is used by Prisma for schema operations (`prisma db push`,
# `prisma migrate`). Locally it can match DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/bookhaven?schema=public"

# --- Production (Neon via Vercel Marketplace integration) ----------------
# DATABASE_URL  : pooled connection string (host contains `-pooler`),
#                 used by the app at runtime in Vercel serverless functions.
# DIRECT_URL    : unpooled connection string (no `-pooler` in host),
#                 used by `prisma db push` / `prisma migrate`.
# Both are auto-injected into Vercel projects by the Neon integration as
# DATABASE_URL and DATABASE_URL_UNPOOLED — copy DATABASE_URL_UNPOOLED into
# DIRECT_URL in the Vercel env vars UI.
