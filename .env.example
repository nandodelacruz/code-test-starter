# PostgreSQL connection strings used by Prisma (see prisma/schema.prisma).
# Copy this file to `.env` and adjust credentials, host, port, and database name.
#
# Local example (create the database first, e.g. `createdb bookhaven`):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bookhaven?schema=public"

# Same connection string as DATABASE_URL for local Postgres (no pooler).
# On Vercel + Neon, both DATABASE_URL (pooled) and DATABASE_URL_UNPOOLED are set for you.
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/bookhaven?schema=public"
