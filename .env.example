# PostgreSQL connection string used by Prisma (see prisma/schema.prisma).
# Copy this file to `.env` and adjust credentials, host, port, and database name.
#
# Local example (create the database first, e.g. `createdb bookhaven`):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bookhaven?schema=public"

# --- Neon + Vercel --------------------------------------------------------
# Neon’s integration sets DATABASE_URL for you (usually the pooled URL — fine for
# the running Next.js app on Vercel). No second env var is required in Prisma.
#
# For one-off schema work against Neon from your machine (`prisma db push`,
# `prisma migrate`), override DATABASE_URL with Neon’s unpooled connection string
# (Neon UI / Vercel: DATABASE_URL_UNPOOLED), e.g.:
#
#   DATABASE_URL="<paste-unpooled-url>" npx prisma db push
#   DATABASE_URL="<paste-unpooled-url>" npm run db:seed
